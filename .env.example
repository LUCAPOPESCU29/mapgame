# Europa Temporis — Environment Variables
# Copy this file to .env (no API keys needed — runs on local Ollama)

# Ollama endpoint (default: http://localhost:11434)
# VITE_OLLAMA_URL=http://localhost:11434

# Model to use — must be pulled in Ollama first:  ollama pull qwen3:6b
# VITE_OLLAMA_MODEL=qwen3:6b
